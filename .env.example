# Compose-level shared configuration. Copy to .env and adjust as needed.

# --- Database ---
MYSQL_DATABASE=learntrack
MYSQL_USER=learntrack
MYSQL_PASSWORD=learntrack_secret
MYSQL_ROOT_PASSWORD=root_secret
DB_PORT=3306

# --- Ports ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
PHPMYADMIN_PORT=8080

# --- URLs (used by backend CORS/Sanctum config and frontend API client) ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
